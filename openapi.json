{
  "openapi": "3.0.3",
  "info": {
    "title": "Mooring Data Generator API",
    "description": "API specification for mooring data generated by mooring-data-generator",
    "version": "1.0.0"
  },
  "paths": {
    "/": {
      "post": {
        "summary": "Receive mooring data",
        "description": "Endpoint that receives generated mooring data via HTTP POST",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PortData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully received mooring data"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BerthData": {
        "properties": {
          "name": {
            "pattern": "^Berth [A-Z]$",
            "title": "Name",
            "type": "string"
          },
          "bollard_count": {
            "exclusiveMaximum": 40,
            "exclusiveMinimum": 0,
            "title": "Bollard Count",
            "type": "integer"
          },
          "hook_count": {
            "exclusiveMaximum": 60,
            "exclusiveMinimum": 0,
            "title": "Hook Count",
            "type": "integer"
          },
          "ship": {
            "$ref": "#/$defs/ShipData"
          },
          "radars": {
            "items": {
              "$ref": "#/$defs/RadarData"
            },
            "title": "Radars",
            "type": "array"
          },
          "bollards": {
            "items": {
              "$ref": "#/$defs/BollardData"
            },
            "title": "Bollards",
            "type": "array"
          }
        },
        "required": [
          "name",
          "bollard_count",
          "hook_count",
          "ship",
          "radars",
          "bollards"
        ],
        "title": "BerthData",
        "type": "object"
      },
      "BollardData": {
        "properties": {
          "name": {
            "pattern": "^BOL[0-9]{3}$",
            "title": "Name",
            "type": "string"
          },
          "hooks": {
            "items": {
              "$ref": "#/$defs/HookData"
            },
            "title": "Hooks",
            "type": "array"
          }
        },
        "required": [
          "name",
          "hooks"
        ],
        "title": "BollardData",
        "type": "object"
      },
      "HookData": {
        "properties": {
          "name": {
            "pattern": "^Hook [1-9][0-9]?$",
            "title": "Name",
            "type": "string"
          },
          "tension": {
            "anyOf": [
              {
                "exclusiveMaximum": 99,
                "minimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tension"
          },
          "faulted": {
            "title": "Faulted",
            "type": "boolean"
          },
          "attached_line": {
            "anyOf": [
              {
                "enum": [
                  "BREAST",
                  "HEAD",
                  "SPRING",
                  "STERN"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Attached Line"
          }
        },
        "required": [
          "name",
          "tension",
          "faulted",
          "attached_line"
        ],
        "title": "HookData",
        "type": "object"
      },
      "RadarData": {
        "properties": {
          "name": {
            "pattern": "^B[A-Z]RD[0-9]$",
            "title": "Name",
            "type": "string"
          },
          "ship_distance": {
            "anyOf": [
              {
                "exclusiveMaximum": 100,
                "minimum": 0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ship Distance"
          },
          "distance_change": {
            "anyOf": [
              {
                "exclusiveMaximum": 100,
                "exclusiveMinimum": -100,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Distance Change"
          },
          "distance_status": {
            "enum": [
              "INACTIVE",
              "ACTIVE"
            ],
            "title": "Distance Status",
            "type": "string"
          }
        },
        "required": [
          "name",
          "ship_distance",
          "distance_change",
          "distance_status"
        ],
        "title": "RadarData",
        "type": "object"
      },
      "ShipData": {
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "vessel_id": {
            "pattern": "^[0-9]{4}$",
            "title": "Vessel Id",
            "type": "string"
          }
        },
        "required": [
          "name",
          "vessel_id"
        ],
        "title": "ShipData",
        "type": "object"
      },
      "PortData": {
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "berths": {
            "items": {
              "$ref": "#/$defs/BerthData"
            },
            "title": "Berths",
            "type": "array"
          }
        },
        "required": [
          "name",
          "berths"
        ],
        "title": "PortData",
        "type": "object"
      }
    }
  }
}
