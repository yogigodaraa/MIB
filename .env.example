# Environment Configuration for BHP Mooring Data Dashboard

# Server Settings
HOST=127.0.0.1
PORT=8000
DEBUG=false
RELOAD=false

# Application Info
APP_NAME="BHP Mooring Data Dashboard"
VERSION="1.0.0"

# Data Management
DATA_RETENTION_HOURS=24
MAX_HISTORY_ENTRIES=100
MAX_TENSION_HISTORY=50

# Alert Thresholds (JSON format)
ALERT_THRESHOLDS={"low": 30, "medium": 70, "high": 85, "critical": 95}

# Tension Monitoring Configuration  
TENSION_BUFFER_SIZE=50
OUTLIER_THRESHOLD=2.5
CONFIDENCE_THRESHOLD=0.7
CALIBRATION_DRIFT_LIMIT=5
SMOOTHING_WINDOW=5
PREDICTION_WINDOW=10

# Communication Settings
SMS_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=true
RADIO_ENABLED=false

# Security (Optional)
# API_KEY=your-secret-api-key
CORS_ORIGINS=["*"]

# Logging Configuration
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# Template and Static Files
TEMPLATE_DIRECTORY=templates
STATIC_DIRECTORY=static